NEXT_PUBLIC_DOC_URL=https://github.com/fulaoaz/image-worker/tree/main/docs

# Optional server-managed model provider configuration.
# When set on the server, channels appear in the app without exposing API keys to browsers.
# Single provider:
AI_PROVIDER_ID=server
AI_PROVIDER_NAME=Server Provider
AI_API_FORMAT=openai
AI_BASE_URL=https://api.openai.com
AI_API_KEY=sk-REPLACE_ME
AI_MODELS=gpt-image-2,gpt-5.5,gpt-4o-mini-tts

# Multiple providers can be configured with indexed variables:
# AI_PROVIDER_1_ID=openai
# AI_PROVIDER_1_NAME=OpenAI
# AI_PROVIDER_1_API_FORMAT=openai
# AI_PROVIDER_1_BASE_URL=https://api.openai.com
# AI_PROVIDER_1_API_KEY=sk-REPLACE_ME
# AI_PROVIDER_1_MODELS=gpt-image-2,gpt-5.5
# AI_PROVIDER_2_ID=gemini
# AI_PROVIDER_2_NAME=Gemini
# AI_PROVIDER_2_API_FORMAT=gemini
# AI_PROVIDER_2_BASE_URL=https://generativelanguage.googleapis.com
# AI_PROVIDER_2_API_KEY=REPLACE_ME
# AI_PROVIDER_2_MODELS=gemini-2.5-flash-image

# Or provide all channels as JSON:
# AI_MODEL_CHANNELS=[{"id":"openai","name":"OpenAI","apiFormat":"openai","baseUrl":"https://api.openai.com","apiKey":"sk-REPLACE_ME","models":["gpt-image-2","gpt-5.5"]}]
